FROM python:3.12.7-slim-bookworm

# System dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl ca-certificates jq \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js (required for Claude CLI / Agent SDK)
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/* \
    && npm install -g @anthropic-ai/claude-code@2.1.92

# Python dependencies for sandbox
# langchain-core: athanor.sandbox.runner uses RunnableConfig (type hint only,
# but imported at module load via cast()).
RUN pip install --no-cache-dir \
    "claude-agent-sdk>=0.1.48,<0.2" \
    "structlog>=24.0,<26" \
    "httpx>=0.27,<1" \
    "langchain-core>=0.3,<1"

# Sandbox code (runs inside container).
# athanor/agents/ + the docker_client/auth_provider/agent_runner subset are
# imported transitively from athanor.sandbox.runner -> executor_factory ->
# SdkAgentExecutor; the sandbox runner cannot start without them.
#
# sandbox_manager.py is intentionally NOT copied: the runner only needs
# AgentOutput (a dataclass) from agent_runner.py and never instantiates
# AgentRunner. agent_runner guards its SandboxManager import behind
# TYPE_CHECKING so loading the module does not transitively pull in
# image_registry / cache_manager / etc. — modules that don't belong inside
# the sandbox.
COPY athanor/sandbox/ /app/athanor/sandbox/
COPY athanor/safety/ /app/athanor/safety/
COPY athanor/agents/ /app/athanor/agents/
COPY athanor/execution/events.py /app/athanor/execution/events.py
COPY athanor/execution/agent_runner.py /app/athanor/execution/agent_runner.py
COPY athanor/execution/auth_provider.py /app/athanor/execution/auth_provider.py
COPY athanor/execution/docker_client.py /app/athanor/execution/docker_client.py

# Make athanor packages importable
RUN mkdir -p /app/athanor/execution && \
    touch /app/athanor/__init__.py /app/athanor/execution/__init__.py

ENV PYTHONPATH=/app

# Non-root user
RUN useradd --create-home agent

# Create writable workspace (tmpfs in docker run, but need the dir)
RUN mkdir -p /workspace && chown agent:agent /workspace

USER agent
WORKDIR /workspace
