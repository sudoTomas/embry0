FROM python:3.12.7-slim-bookworm AS base

# Upgrade OS packages first — the pinned base tag ships a CRITICAL OpenSSL
# (CVE-2026-31789) whose fix is already in the Debian repos.
RUN apt-get update && apt-get upgrade -y && rm -rf /var/lib/apt/lists/*

# System dependencies — base + Playwright/Chromium runtime libraries.
#
# Without the libnss3/libgbm1/libxkbcommon0/libdrm2/etc. set, every QA
# sub-task's agent reports `Browser automation could not be executed
# (slim sandbox missing libglib-2.0.so.0, libX11.so.6, libgtk-3.so.0 …
# required by Chromium and Firefox headless shells)` and falls back to
# HTTP probing + source-code analysis. That degraded mode produces
# inconclusive results and zero screenshots — the QA agent's whole
# reason-for-being is browser automation, so these libs are required,
# not optional. List drawn from `npx playwright install-deps`'s
# bookworm package set.
RUN apt-get update && apt-get install -y --no-install-recommends \
        git curl ca-certificates jq \
        # Playwright / Chromium runtime
        libnss3 libnspr4 libatk1.0-0 libatk-bridge2.0-0 libcups2 \
        libdbus-1-3 libdrm2 libxkbcommon0 libxcomposite1 libxdamage1 \
        libxfixes3 libxrandr2 libgbm1 libpango-1.0-0 libcairo2 \
        libasound2 libatspi2.0-0 libxshmfence1 libx11-6 libxcb1 \
        libxext6 libgtk-3-0 libglib2.0-0 \
        # Fonts so headless Chromium can render text without subs
        fonts-liberation fonts-noto-color-emoji \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js (required for Claude CLI / Agent SDK + Playwright runtime)
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/* \
    # npm self-upgrade — nodesource bundles an npm whose vendored tar carries
    # CRITICAL CVE-2026-59873 (fixed in tar >= 7.5.19).
    && npm install -g npm@latest \
    && npm install -g @anthropic-ai/claude-code@2.1.92

# Python dependencies for sandbox
# langchain-core: embry0.sandbox.runner uses RunnableConfig (type hint only,
# but imported at module load via cast()).
RUN pip install --no-cache-dir \
    "claude-agent-sdk>=0.1.48,<0.2" \
    "anthropic>=0.69,<1" \
    "structlog>=24.0,<26" \
    "httpx>=0.27,<1" \
    "langchain-core>=0.3,<1"

# Sandbox code (runs inside container).
# embry0/agents/ + the docker_client/auth_provider/agent_runner subset are
# imported transitively from embry0.sandbox.runner -> executor_factory ->
# SdkAgentExecutor; the sandbox runner cannot start without them.
#
# sandbox_manager.py is intentionally NOT copied: the runner only needs
# AgentOutput (a dataclass) from agent_runner.py and never instantiates
# AgentRunner. agent_runner guards its SandboxManager import behind
# TYPE_CHECKING so loading the module does not transitively pull in
# image_registry / cache_manager / etc. — modules that don't belong inside
# the sandbox.
COPY embry0/sandbox/ /app/embry0/sandbox/
COPY embry0/safety/ /app/embry0/safety/
COPY embry0/agents/ /app/embry0/agents/
COPY embry0/execution/events.py /app/embry0/execution/events.py
COPY embry0/execution/agent_runner.py /app/embry0/execution/agent_runner.py
COPY embry0/execution/auth_provider.py /app/embry0/execution/auth_provider.py
COPY embry0/execution/docker_client.py /app/embry0/execution/docker_client.py

# Make embry0 packages importable
RUN mkdir -p /app/embry0/execution && \
    touch /app/embry0/__init__.py /app/embry0/execution/__init__.py

ENV PYTHONPATH=/app

# Non-root user
RUN useradd --create-home agent

# Create writable workspace (tmpfs in docker run, but need the dir)
RUN mkdir -p /workspace && chown agent:agent /workspace

USER agent
WORKDIR /workspace

# --- dev-python -------------------------------------------------------------
# Lean dev-check toolchain for Poetry-based Python repos. Same base as the
# slim sandbox: no Chromium, no Docker CLI, no JDK. Repo dependencies are
# installed per-job by the agent (`poetry install`), not baked here.
FROM base AS dev-python
USER root
RUN pip install --no-cache-dir "poetry==1.8.4"
USER agent
WORKDIR /workspace
