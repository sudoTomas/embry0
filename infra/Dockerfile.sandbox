FROM python:3.12-slim-bookworm

# System dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl ca-certificates jq \
    && rm -rf /var/lib/apt/lists/*

# Python dependencies for sandbox
RUN pip install --no-cache-dir \
    "claude-agent-sdk>=0.1.48,<0.2" \
    "structlog>=24.0,<26" \
    "httpx>=0.27,<1"

# Sandbox code (runs inside container)
COPY legion/sandbox/ /app/legion/sandbox/
COPY legion/safety/ /app/legion/safety/
COPY legion/execution/events.py /app/legion/execution/events.py

# Make legion packages importable
RUN mkdir -p /app/legion/execution && \
    touch /app/legion/__init__.py /app/legion/execution/__init__.py

ENV PYTHONPATH=/app

# Non-root user
RUN useradd --create-home agent

USER agent
WORKDIR /workspace
