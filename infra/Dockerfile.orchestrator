FROM python:3.12.7-slim-bookworm

# System dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl ca-certificates gnupg libpq-dev \
    && install -m 0755 -d /etc/apt/keyrings \
    && curl -fsSL https://download.docker.com/linux/debian/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg \
    && chmod a+r /etc/apt/keyrings/docker.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] \
       https://download.docker.com/linux/debian bookworm stable" > /etc/apt/sources.list.d/docker.list \
    && apt-get update && apt-get install -y --no-install-recommends docker-ce-cli \
    && rm -rf /var/lib/apt/lists/*

# Python dependencies (copy minimal package for metadata, then install deps)
COPY pyproject.toml /app/
COPY embry0/__init__.py /app/embry0/__init__.py
WORKDIR /app
RUN pip install --no-cache-dir . psycopg[binary]

# Install Node.js (required for Claude CLI / Agent SDK)
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/* \
    && npm install -g @anthropic-ai/claude-code@2.1.92

# Application code (overwrite with full source)
COPY embry0/ /app/embry0/

# Non-root user
RUN useradd --create-home orchestrator \
    && mkdir -p /data \
    && chown orchestrator:orchestrator /data

USER orchestrator

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD curl --fail http://localhost:8000/health || exit 1

CMD ["uvicorn", "embry0.api.app:create_app", "--factory", \
     "--host", "0.0.0.0", "--port", "8000", \
     "--log-level", "info", \
     "--timeout-graceful-shutdown", "30", \
     "--timeout-keep-alive", "65"]
