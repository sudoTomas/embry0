# =============================================================================
# embry0 Configuration
# =============================================================================

# --- Database ---
# Required in production. Generate with: openssl rand -hex 20
# (defined before DATABASE_URL because compose interpolates env files top-down)
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://embry0:${POSTGRES_PASSWORD}@postgres:5432/embry0
POSTGRES_DB=embry0
POSTGRES_USER=embry0

# --- Provider (pick one: anthropic_api | claude_max | ollama) ---
PROVIDER_MODE=anthropic_api
DEFAULT_MODEL=
MODEL_HEAVY=claude-opus-4-7
MODEL_MEDIUM=claude-sonnet-4-6
MODEL_LIGHT=claude-haiku-4-5

# Anthropic API (per-token billing)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
# Set true ONLY when something is wired to consume auth_proxy_url. The
# proxy holds ANTHROPIC_API_KEY in its env, so leave false unless needed.
AUTH_PROXY_ENABLED=false

# Claude Max (OAuth passthrough — flat rate)
# PROVIDER_MODE=claude_max

# Claude Code OAuth token. Used by sandbox-side Claude CLI runs and the
# Agent SDK triage calls (the orchestrator reads it from its environment).
# Get one with `claude setup-token`, or copy the accessToken from
# ~/.claude/.credentials.json (claudeAiOauth.accessToken).
CLAUDE_CODE_OAUTH_TOKEN=

# Ollama (local inference)
# PROVIDER_MODE=ollama
# OLLAMA_BASE_URL=http://gpu-server:11434
# OLLAMA_MODEL=codellama

# --- GitHub ---
GITHUB_TOKEN=ghp_your-github-personal-access-token
# Per-owner GitHub tokens: a fine-grained PAT is single-owner, so add one per
# org/user; GITHUB_TOKEN stays the global fallback. Owner is uppercased with
# '-' -> '_'. These live in THIS file (the repo-root .env is the
# orchestrator's env_file) — not infra/.env.
# GITHUB_TOKEN__MY_ORG=github_pat_...
# GITHUB_TOKEN__ANOTHER_ORG=github_pat_...
# Leave empty for local dev with smee.io (requires WEBHOOK_DEV_MODE=true below).
# For production, generate with: openssl rand -hex 20
GITHUB_WEBHOOK_SECRET=

# --- Budget & Limits ---
MAX_BUDGET_USD=10.0
DAILY_BUDGET_CAP_USD=100.0
MONTHLY_BUDGET_CAP_USD=500.0
BUDGET_OVERRUN_MODE=soft
RATE_LIMIT_PER_AUTHOR_PER_HOUR=5
API_RATE_LIMIT_PER_MINUTE=60

# --- API ---
# REQUIRED in production — bearer token for the orchestrator API and dashboard.
# Generate with: python -c 'import secrets; print(secrets.token_hex(32))'
API_KEY=
# Frontend WebSocket auth. Inlined into the frontend bundle at build time
# (Vite convention — VITE_* vars are public; anyone who can load the dashboard
# can use this key directly against the API). The compose `frontend` build arg
# defaults this to ${API_KEY}, so leaving it blank here is fine — set it
# explicitly only if you want the frontend to use a different key from the
# backend (e.g. a read-only client).
VITE_API_KEY=
# Per-surface dev-mode flags. Each independently bypasses one auth check.
# AUTH_DEV_MODE: bypasses Bearer-token API auth. NEVER use in production.
# WEBHOOK_DEV_MODE: bypasses webhook HMAC. Required for the smee.io relay flow.
# DEPRECATED: DEV_MODE=true is honoured for one release as a compat shim
# (treats as both flags true). Remove in next release.
AUTH_DEV_MODE=false
WEBHOOK_DEV_MODE=false
ALLOWED_CORS_ORIGINS=http://localhost:3001
TRIGGER_LABELS=embry0

# --- Secrets ---
# Fernet key for encrypting per-repo env var secrets at rest.
# Generate with: openssl rand -hex 32
# If unset, an insecure default is used (logs a warning on startup).
# Rotating this key makes previously-encrypted secrets undecryptable.
ENVIRONMENT_SECRET_KEY=

# Shared secret between orchestrator and credential proxies. Required in
# production. Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
PROXY_ADMIN_TOKEN=

# --- Sandbox Defaults ---
SANDBOX_IMAGE=embry0-sandbox:latest
SANDBOX_MEMORY=8g
SANDBOX_CPUS=4
# Container registry prefix applied to embry0-* images at DinD-launch time.
# The bootstrapped compose stack runs a sidecar registry on the backend network
# (matching the value below). On a K8s migration this becomes the production
# registry URL (e.g. ghcr.io/your-org) — the same code paths apply, no rewrite
# needed. Empty disables qualification (useful for environments that side-load
# images directly into the daemon).
IMAGE_REGISTRY=registry:5000
# Pluggable agent execution modes. Defaults preserve the standard runtime
# behavior (Agent SDK path + OAuth via CLAUDE_CODE_OAUTH_TOKEN).
# DEFAULT_EXECUTION_MODE=sdk
# DEFAULT_AUTH_MODE=oauth
# How many hours a paused job keeps its sandbox alive before expiring.
PAUSED_JOB_TTL_HOURS=48

# --- Notifications (optional) ---
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Public URL Telegram should call back when a user replies. Required for
# inbound Telegram answers (Plan B). Outbound notifications work without
# it. Example: https://embry0.your-tunnel.com/api/v1/telegram/webhook
TELEGRAM_WEBHOOK_URL=

# --- Dashboard public URL ---
# Used in GitHub-comment notifications as the deep-link users click to
# answer agent questions ("Answer at: <DASHBOARD_PUBLIC_URL>/issues/{id}").
# Localhost works for local dev; in production set to whatever public URL
# exposes the dashboard (Cloudflare tunnel, VPN host, etc.). Orchestrator
# logs a warning at startup if left at localhost outside dev mode.
DASHBOARD_PUBLIC_URL=http://localhost:8200

# --- Audit ---
AUDIT_LOG_PATH=/data/audit.jsonl

# --- Infrastructure ---
PROD_PORT=8200
ORCHESTRATOR_CPUS=4
ORCHESTRATOR_MEMORY=4G
DIND_CPUS=4
DIND_MEMORY=8G
TZ=America/New_York

# --- Cloudflare Tunnel (production webhook ingress) ---
# Provision a Cloudflare tunnel (dashboard or `cloudflared tunnel create`)
# and paste its token here.
# When empty, the cloudflared container starts in a restart loop — that's
# intentional. The orchestrator dashboard on :8200 still works on the LAN
# regardless; only public webhook ingress depends on this token.
# Set both keys to the same value (TUNNEL_TOKEN is the name cloudflared reads;
# CLOUDFLARED_TUNNEL_TOKEN is the canonical name used in this project).
CLOUDFLARED_TUNNEL_TOKEN=
TUNNEL_TOKEN=

# MinIO — QA artifact storage (private bucket, served via orchestrator-side
# presigned URLs only). Do NOT expose ports publicly.
MINIO_ROOT_USER=embry0
# REQUIRED: generate with `openssl rand -hex 16` (compose refuses to start
# without it).
MINIO_ROOT_PASSWORD=
QA_ARTIFACT_RETENTION_DAYS=14
# MinIO endpoints — override only for non-compose deployments. The defaults
# match the compose service (orchestrator-side) and the in-DinD minio-proxy
# (sandbox-side, load-bearing for presigned-URL signatures).
# MINIO_ENDPOINT=minio:9000
# MINIO_SANDBOX_ENDPOINT=minio-proxy:9100

# --- Turbo remote cache (optional, infra/docker-compose.cache.yml) ---
# Auth token for the self-hosted turborepo-remote-cache overlay. Only needed
# when deploying that overlay; see the header of docker-compose.cache.yml.
# TURBO_REMOTE_CACHE_TOKEN=

# --- Linear dispatch helper (optional, scripts/dispatch-embry0) ---
# Only needed to dispatch Linear tickets as jobs from the CLI helper.
# LINEAR_API_KEY=
# Base URL + API key of the embry0 instance the helper POSTs to.
# EMBRY0_URL=http://localhost:8200
# EMBRY0_API_KEY=
