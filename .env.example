# =============================================================================
# Legion Configuration
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql://legion:${POSTGRES_PASSWORD:-legion}@postgres:5432/legion
POSTGRES_PASSWORD=legion
POSTGRES_DB=legion
POSTGRES_USER=legion

# --- Provider (pick one: anthropic_api | claude_max | ollama) ---
PROVIDER_MODE=anthropic_api
DEFAULT_MODEL=
MODEL_HEAVY=claude-opus-4-6
MODEL_MEDIUM=claude-sonnet-4-6
MODEL_LIGHT=claude-haiku-4-5

# Anthropic API (per-token billing)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Claude Max (OAuth passthrough — flat rate)
# PROVIDER_MODE=claude_max
# CLAUDE_MAX_OAUTH_TOKEN=your-oauth-token-here

# Ollama (local inference)
# PROVIDER_MODE=ollama
# OLLAMA_BASE_URL=http://gpu-server:11434
# OLLAMA_MODEL=codellama

# --- GitHub ---
GITHUB_TOKEN=ghp_your-github-personal-access-token
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# --- Budget & Limits ---
MAX_BUDGET_USD=10.0
DAILY_BUDGET_CAP_USD=100.0
MONTHLY_BUDGET_CAP_USD=500.0
BUDGET_OVERRUN_MODE=soft
RATE_LIMIT_PER_AUTHOR_PER_HOUR=5
API_RATE_LIMIT_PER_MINUTE=60

# --- API ---
API_KEY=
DEV_MODE=false
ALLOWED_CORS_ORIGINS=http://localhost:3001
TRIGGER_LABELS=Legion

# --- Sandbox Defaults ---
SANDBOX_IMAGE=legion-sandbox:latest
SANDBOX_MEMORY=8g
SANDBOX_CPUS=4

# --- Notifications (optional) ---
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Audit ---
AUDIT_LOG_PATH=/data/audit.jsonl

# --- Infrastructure ---
PROD_PORT=8200
ORCHESTRATOR_CPUS=4
ORCHESTRATOR_MEMORY=4G
DIND_CPUS=4
DIND_MEMORY=8G
TZ=America/New_York
