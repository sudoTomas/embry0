#!/usr/bin/env bash
set -euo pipefail

# ─── Claude Code shortcut into the running production orchestrator ─────────
# This script opens a Claude Code session inside the athanor-orchestrator
# container. The orchestrator must already be running via:
#   cd infra && docker compose up -d
#
# Usage:
#   ./lab              — open Claude Code (default)
#   ./lab claude       — same as above, with optional extra args forwarded
#   ./lab help         — show this message

CONTAINER="athanor-orchestrator"

cd "$(dirname "$0")"

TTY_FLAGS=""
if [ -t 0 ]; then
  TTY_FLAGS="-it"
fi

case "${1:-claude}" in
  claude)
    shift 2>/dev/null || true
    exec docker exec $TTY_FLAGS -w /workspace "$CONTAINER" \
      claude --dangerously-skip-permissions "$@"
    ;;
  help|--help|-h)
    echo "Usage: ./lab [claude] [extra-claude-args...]"
    echo ""
    echo "Opens Claude Code inside the running athanor-orchestrator container."
    echo "The container must be started first: cd infra && docker compose up -d"
    echo ""
    echo "Commands:"
    echo "  claude  Open Claude Code (default if no args)"
    echo "  help    Show this message"
    ;;
  *)
    echo "Unknown command: $1"
    echo "Run ./lab help for usage"
    exit 1
    ;;
esac
